# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ============================================================
# Auth0 (https://manage.auth0.com)
# ============================================================
# Generate with: openssl rand -hex 32
AUTH0_SECRET=

# Local dev: http://localhost:3000
# Production: set AUTH0_BASE_URL=https://your-domain.com on Vercel (NOT here)
AUTH0_BASE_URL=http://localhost:3000

# Tenant URL — Auth0 dashboard → Settings → Domain. MUST start with https://
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ============================================================
# Supabase (https://supabase.com/dashboard)
# ============================================================
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# IMPORTANT: server-side only, bypasses RLS — never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# App config
# ============================================================
# Email of the only user allowed to write via the dashboard
ADMIN_EMAIL=
